{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./lib/*"]
    }
  },
  "include": ["entrypoints/**/*", "lib/**/*", ".wxt/types/*.d.ts", ".wxt/**/*.d.ts"]
}
